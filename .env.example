# --- Analytics ---
# Google Tag Manager container (GTM-XXXXXXX). GA4 + Microsoft Clarity se
# configuran DENTRO del contenedor GTM, no aquí. Sin esta variable el sitio
# funciona igual, solo sin GTM.
NEXT_PUBLIC_GTM_ID=

# --- Formulario de contacto (Resend) ---
# API key de https://resend.com (gratis hasta 3.000 emails/mes)
RESEND_API_KEY=
# Remitente: usa onboarding@resend.dev hasta verificar el dominio en Resend,
# luego cámbialo a algo como "Web <web@byrongonzalez.com.co>"
CONTACT_FROM=Web <onboarding@resend.dev>
# Correo donde recibes los mensajes del formulario
CONTACT_TO=byrongonzalezing@gmail.com
